<!--
  Service-level policy. Sets organisation-wide defaults. All workspace and
  API policies must <base /> back into this.

  Reference: centralized policy governance with <base/> inheritance
  enumerates the controls that belong at service scope:
    - Security headers: CORS, CSP, HSTS, X-Content-Type-Options
    - Centralized logging: distributed tracing into Application Insights
    - Global rate-limiting defaults
    - IP restrictions / JWT validation for sensitive workloads
-->
<policies>
    <inbound>
        <set-header name="X-Correlation-Id" exists-action="skip">
            <value>@(context.RequestId)</value>
        </set-header>
        <!-- Global rate-limit default. Per-product / per-team overrides
             happen at lower scopes. -->
        <rate-limit-by-key calls="1000" renewal-period="60"
                           counter-key="@(context.Subscription.Id ?? &quot;anon&quot;)" />
        <!-- CORS. Tighten per product when a stricter list is needed. -->
        <cors allow-credentials="false">
            <allowed-origins>
                <origin>https://*.contoso.com</origin>
            </allowed-origins>
            <allowed-methods>
                <method>GET</method>
                <method>POST</method>
                <method>PUT</method>
                <method>PATCH</method>
                <method>DELETE</method>
            </allowed-methods>
            <allowed-headers>
                <header>*</header>
            </allowed-headers>
        </cors>
        <!--
          JWT validation is parameterised via the platform-owned named values
          'platform-jwt-issuer' / 'platform-jwt-audience'. Disabled by default
          here so the sample backends keep working without an Entra tenant
          configured; remove the 'when' guard for production use.
        -->
        <choose>
            <when condition="@(context.Variables.GetValueOrDefault&lt;string&gt;(&quot;require-jwt&quot;, &quot;false&quot;) == &quot;true&quot;)">
                <validate-jwt header-name="Authorization" failed-validation-httpcode="401"
                              require-scheme="Bearer" require-expiration-time="true"
                              require-signed-tokens="true">
                    <openid-config url="{{platform-jwt-openid-config-url}}" />
                    <required-claims>
                        <claim name="aud">
                            <value>{{platform-jwt-audience}}</value>
                        </claim>
                    </required-claims>
                </validate-jwt>
            </when>
        </choose>
    </inbound>
    <backend>
        <forward-request timeout="30" />
    </backend>
    <outbound>
        <!-- Security response headers. -->
        <set-header name="Strict-Transport-Security" exists-action="override">
            <value>max-age=31536000; includeSubDomains</value>
        </set-header>
        <set-header name="Content-Security-Policy" exists-action="override">
            <value>default-src 'none'; frame-ancestors 'none'</value>
        </set-header>
        <set-header name="X-Content-Type-Options" exists-action="override">
            <value>nosniff</value>
        </set-header>
        <set-header name="Referrer-Policy" exists-action="override">
            <value>no-referrer</value>
        </set-header>
        <set-header name="X-Powered-By" exists-action="delete" />
        <set-header name="Server" exists-action="delete" />
    </outbound>
    <on-error>
        <set-header name="X-Correlation-Id" exists-action="override">
            <value>@(context.RequestId)</value>
        </set-header>
    </on-error>
</policies>
